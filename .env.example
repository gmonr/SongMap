# Copy to .env.local and fill in from your Supabase project settings
# (Project Settings -> API). Without these the app runs in demo mode:
# the bundled demo song is viewable but nothing can be saved.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: route Ultimate Guitar fetches through a scraping API when the
# built-in free relays prove flaky. {url} is replaced with the URI-encoded
# target page, {rawUrl} with the target verbatim. See "Ultimate Guitar
# search" in README.md for examples (ScraperAPI, scrape.do).
# UG_PROXY_TEMPLATE=
